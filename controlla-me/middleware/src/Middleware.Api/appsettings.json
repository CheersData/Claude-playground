{
  "ConnectionStrings": {
    "Postgres": "${DATABASE_URL}"
  },
  "Middleware": {
    "CacheTtlSeconds": 60
  },
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:3000"
    ]
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.Hosting.Lifetime": "Information",
      "Npgsql": "Warning"
    }
  },
  "AllowedHosts": "*"
}

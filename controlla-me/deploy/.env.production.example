# =============================================================================
# .env.production — Production environment variables for Poimandres (Hetzner VM)
# Copy this to deploy/.env.production and fill in all values
# =============================================================================
#
# NEVER commit .env.production to git!
# This file is shared between Next.js and Trading containers via docker-compose
#

# =============================================================================
# Supabase (REQUIRED)
# =============================================================================
NEXT_PUBLIC_SUPABASE_URL=https://xxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# =============================================================================
# Anthropic (REQUIRED for legal analysis pipeline)
# =============================================================================
ANTHROPIC_API_KEY=sk-ant-...

# =============================================================================
# Google Gemini (recommended — Corpus Agent + Question-Prep fallback)
# =============================================================================
GEMINI_API_KEY=
GEMINI_API_KEY_ALT=

# =============================================================================
# AI Providers (optional — tier system fallback chain)
# =============================================================================
# OpenAI
OPENAI_API_KEY=

# Mistral (free tier: all models, 2 RPM)
MISTRAL_API_KEY=
MISTRAL_API_KEY_ALT=

# Groq (free tier: 1000 req/day)
GROQ_API_KEY=
GROQ_API_KEY_ALT=

# Cerebras (free tier: 24M tok/day)
CEREBRAS_API_KEY=
CEREBRAS_API_KEY_ALT=

# SambaNova (free tier: 200K tok/day)
SAMBANOVA_API_KEY=
SAMBANOVA_API_KEY_ALT=

# =============================================================================
# Stripe (REQUIRED for payments)
# =============================================================================
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_PRO_PRICE_ID=price_...
STRIPE_SINGLE_PRICE_ID=price_...

# =============================================================================
# Voyage AI (recommended — embeddings for vector DB)
# =============================================================================
VOYAGE_API_KEY=pa-...

# =============================================================================
# Application URLs
# =============================================================================
NEXT_PUBLIC_APP_URL=https://poimandres.work
NODE_ENV=production

# =============================================================================
# Security (REQUIRED in production)
# =============================================================================
# Console JWT secret — min 32 chars
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CONSOLE_JWT_SECRET=

# Cron secret — required for scheduled jobs
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CRON_SECRET=

# =============================================================================
# Upstash Redis (REQUIRED for distributed rate limiting)
# =============================================================================
UPSTASH_REDIS_REST_URL=https://...
UPSTASH_REDIS_REST_TOKEN=

# =============================================================================
# Telegram (recommended — company notifications)
# =============================================================================
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# =============================================================================
# Google Analytics (optional)
# =============================================================================
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX
NEXT_PUBLIC_GSC_VERIFICATION=

# =============================================================================
# Trading System
# =============================================================================
TRADING_MODE=paper
TRADING_ENABLED=true
TRADING_LOG_LEVEL=INFO

# Alpaca — slope account (intraday)
ALPACA_API_KEY=
ALPACA_SECRET_KEY=
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# Alpaca — conventional account (daily, optional)
ALPACA_CONV_API_KEY=
ALPACA_CONV_SECRET_KEY=
ALPACA_CONV_BASE_URL=https://paper-api.alpaca.markets

# Alpaca — crypto account (optional)
ALPACA_CRYPTO_API_KEY=
ALPACA_CRYPTO_SECRET_KEY=
ALPACA_CRYPTO_BASE_URL=https://paper-api.alpaca.markets

# Tiingo — market data real-time
TIINGO_API_KEY=
USE_TIINGO_FOR_MARKET_DATA=true
TIINGO_REQUESTS_PER_HOUR=5000
TIINGO_NEWS_ENABLED=true
TIINGO_NEWS_MINUTES_BACK=30
TIINGO_NEWS_HIGH_IMPACT_ONLY=true

# FRED — macro data (optional)
FRED_API_KEY=

# =============================================================================
# Integration Office (OAuth connectors)
# =============================================================================
# Credential vault encryption key — min 32 chars
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
VAULT_ENCRYPTION_KEY=

# Google Drive OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# HubSpot OAuth
HUBSPOT_CLIENT_ID=
HUBSPOT_CLIENT_SECRET=

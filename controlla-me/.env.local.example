NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
ANTHROPIC_API_KEY=

# Google Gemini — LLM secondario per Corpus Agent e Question-Prep (opzionale, fallback a Haiku)
# Genera su https://aistudio.google.com/apikey
GEMINI_API_KEY=

# OpenAI — GPT-4o, GPT-4.1, GPT-4o Mini, GPT-4.1 Nano (opzionale)
# Genera su https://platform.openai.com/api-keys
# NOTA: la subscription ChatGPT Plus NON include crediti API
OPENAI_API_KEY=

# Mistral — Mistral Large, Small, Nemo (opzionale, free tier: tutti i modelli, 2 RPM)
# Genera su https://console.mistral.ai/api-keys
MISTRAL_API_KEY=

# Groq — Llama 4 Scout, Llama 3.3 70B (opzionale, free tier: 1000 req/giorno)
# Genera su https://console.groq.com/keys
GROQ_API_KEY=

# Cerebras — Llama 3.3 70B (opzionale, free tier: 1M token/giorno)
# Genera su https://cloud.cerebras.ai/
CEREBRAS_API_KEY=

# DeepSeek — DeepSeek V3, R1 (opzionale, 5M token gratis)
# Genera su https://platform.deepseek.com/api_keys
# ⚠️ Server in Cina: NON usare per documenti legali sensibili
DEEPSEEK_API_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_PRO_PRICE_ID=
STRIPE_SINGLE_PRICE_ID=
# Voyage AI — embeddings per il vector DB legale (opzionale)
# Registrati su https://dash.voyageai.com/ per ottenere la chiave
# Usa voyage-law-2 (specifico per testi legali) — configurato di default
VOYAGE_API_KEY=

NEXT_PUBLIC_APP_URL=http://localhost:3000

# Google Analytics 4 (opzionale — tracking utenti)
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Telegram Bot — CME Company Scheduler (necessario per il daemon di approvazione piani)
# 1. Parla con @BotFather su Telegram → /newbot → copia TOKEN
# 2. Scopri il tuo CHAT_ID: npx tsx scripts/company-scheduler-daemon.ts --setup
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Console (obbligatorio in produzione)
CONSOLE_JWT_SECRET=change-me-min-32-chars-xxxxxxxxxxxxxxxxx
CRON_SECRET=change-me-random-secret-for-cron-endpoints

# Upstash Redis (per rate limiting distribuito in produzione)
UPSTASH_REDIS_REST_URL=https://your-instance.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-token-here

# Tiingo — market data real-time (IEX zero delay, free tier: 50 req/h)
# Genera su https://api.tiingo.com/ — free plan include tutti gli ETF/equity US
# Piano Power/Enterprise ($10-30/mese): 5000+ req/h — necessario per intraday
TIINGO_API_KEY=
USE_TIINGO_FOR_MARKET_DATA=true
TIINGO_REQUESTS_PER_HOUR=5000

# Tiingo News API — blocca segnali durante breaking news (Fed, tariff, crash)
# Richiede piano Power — se free tier, disabilitare con false
TIINGO_NEWS_ENABLED=true
TIINGO_NEWS_MINUTES_BACK=30
TIINGO_NEWS_HIGH_IMPACT_ONLY=true

# Trading — configurazione generale
TRADING_MODE=paper
TRADING_ENABLED=true
TRADING_LOG_LEVEL=INFO

# Alpaca — account slope (intraday 24/7, strategy slope+volume)
# Genera su https://alpaca.markets/ — usa paper trading per test
ALPACA_API_KEY=
ALPACA_SECRET_KEY=
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# Alpaca — Conventional account (daily MACD/RSI/BB strategy — account separato)
# Opzionale: se non configurato, il sistema usa il slope account come fallback
ALPACA_CONV_API_KEY=
ALPACA_CONV_SECRET_KEY=
ALPACA_CONV_BASE_URL=https://paper-api.alpaca.markets

# Alpaca — Crypto account (BTC/ETH slope 24/7, inclusi weekend)
# Opzionale: se non configurato, il crypto pipeline viene saltato silenziosamente
ALPACA_CRYPTO_API_KEY=
ALPACA_CRYPTO_SECRET_KEY=
ALPACA_CRYPTO_BASE_URL=https://paper-api.alpaca.markets

# FRED — Federal Reserve Economic Data (opzionale, dati macro per analisi)
# Genera su https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=

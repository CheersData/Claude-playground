# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.local.example
!deploy/.env.production.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# analysis cache (local agent results)
.analysis-cache/

# music uploads (local audio files)
.music-uploads/

# Windows reserved device names (Turbopack crash)
nul

# Playwright reports and results
playwright-report/
playwright-results.json

# Test run results (ephemeral)
scripts/testbook-results-*.json
scripts/adversarial-results-*.json
scripts/*-articles.json

# Trading backtest results (raw data ephemeral, summary tracciato)
trading/backtest-results/*/
trading/backtest-results/grid_*/
!trading/backtest-results/SUMMARY.md

# Trading local SQLite DB
trading/data/*.db

# Supabase temp
supabase/.temp/

# Claude Code local config
.claude/
trading/logs/
trading/.scheduler-heartbeat.json

# CME daemon temp files
.autorun-prompt.tmp
company/autorun-logs/
company/gui-daemon-logs/

# Active session tracker (runtime state)
company/.active-sessions.json

# Deploy runtime files
deploy/.env.production
deploy/logs/
deploy/backups/
